{
  "manifest_version": 3,
  "name": "Stay Focused",
  "version": "1.0.1",
  "description": "Block distracting sites and run focus timer sessions to help you stay on task.",
  "permissions": ["storage", "alarms", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/stay_focused.png",
      "48": "icons/stay_focused.png",
      "128": "icons/stay_focused.png"
    }
  },
  "icons": {
    "16": "icons/stay_focused.png",
    "48": "icons/stay_focused.png",
    "128": "icons/stay_focused.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
